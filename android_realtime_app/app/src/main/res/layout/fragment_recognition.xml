<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 当前识别结果大卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recognition_current_title"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp"/>

                <!-- Emoji 图标 -->
                <TextView
                    android:id="@+id/tv_activity_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💤"
                    android:textSize="52sp"
                    android:layout_marginBottom="8dp"/>

                <!-- 运动名称 -->
                <TextView
                    android:id="@+id/tv_activity_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recognition_waiting_data"
                    android:textColor="@color/text"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"/>

                <!-- 置信度进度条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recognition_confidence"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <ProgressBar
                        android:id="@+id/pb_confidence"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/blue"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_confidence_pct"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="—%"
                        android:textColor="@color/blue"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:gravity="end"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 各类别置信度 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recognition_class_confidence"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="14dp"/>

                <!-- 无活动 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_no_activity" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class0"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#94A3B8" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class0" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <!-- 羽毛球 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_badminton" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#EF4444" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class1" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <!-- 跳绳 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_jump_rope" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#10B981" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class2" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <!-- 飞鸟 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_fly" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#3B82F6" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class3" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <!-- 跑步 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_running" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class4"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#F97316" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class4" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

                <!-- 乒乓球 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                        android:text="@string/recognition_class_table_tennis" android:textSize="12sp" android:textColor="@color/text"/>
                    <ProgressBar android:id="@+id/pb_class5"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp" android:layout_height="7dp" android:layout_weight="1"
                        android:max="100" android:progressTint="#8B5CF6" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_class5" android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="0%" android:textSize="11sp" android:textColor="@color/muted" android:fontFamily="monospace" android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 状态卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- 缓冲进度 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recognition_buffer_data"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <ProgressBar
                        android:id="@+id/pb_buffer"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:max="800"
                        android:progress="0"
                        android:progressTint="@color/green"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_buffer_count"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="0/800"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Viterbi 延迟缓冲 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recognition_buffer_viterbi"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <ProgressBar
                        android:id="@+id/pb_viterbi"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:max="180"
                        android:progress="0"
                        android:progressTint="#8B5CF6"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_viterbi_buf"
                        android:layout_width="54dp"
                        android:layout_height="wrap_content"
                        android:text="0/180s"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- 模型状态 -->
                <TextView
                    android:id="@+id/tv_model_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recognition_model_loading"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:gravity="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recognition_summary"
            android:textColor="@color/muted"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <!-- ── 离线示例识别 ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/offline_title"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <Button
                        android:id="@+id/btn_offline_sample"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="40dp"
                        android:text="@string/offline_run_builtin"
                        android:textSize="11sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>

                    <Button
                        android:id="@+id/btn_offline_file"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="40dp"
                        android:layout_marginStart="8dp"
                        android:text="@string/offline_choose_file"
                        android:textSize="11sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_offline"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_offline_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/offline_status_idle"
                    android:textColor="@color/muted"
                    android:textSize="11sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── 活动历史 ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 标题行 + 重置按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recognition_history"
                        android:textColor="@color/text"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btn_reset_session"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="36dp"
                        android:text="@string/action_reset"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"/>
                </LinearLayout>

                <!-- 会话统计行 -->
                <LinearLayout
                    android:id="@+id/ll_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tv_session_total"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recognition_session_total_empty"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/tv_session_active"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recognition_session_active_empty"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginBottom="8dp"/>

                <!-- 动态填充的片段列表 (RecognitionFragment 负责填充) -->
                <LinearLayout
                    android:id="@+id/ll_segments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- 空状态提示 -->
                <TextView
                    android:id="@+id/tv_segments_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recognition_segments_empty"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:visibility="visible"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
